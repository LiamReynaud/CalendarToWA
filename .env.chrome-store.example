# Credentials Chrome Web Store API — NE PAS COMMITTER
# Copier: cp .env.chrome-store.example .env.chrome-store
#
# Réutiliser les mêmes OAuth que Alegria_G_Sheet / calendly_to_gsheet / VpDiveTools
# (même compte Google Cloud, API « Chrome Web Store » activée).
# CWS_EXTENSION_ID : Developer Dashboard → votre extension → ID (32 lettres).
#   À renseigner après la première création manuelle de la fiche.

CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_REFRESH_TOKEN=
CWS_EXTENSION_ID=
